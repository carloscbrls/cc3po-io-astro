---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE_TITLE = 'CC3PO - Triple Your Team\'s Output in 90 Days';
const SITE_DESCRIPTION = 'Operational systems consulting that triples team productivity. We eliminate inefficiencies and build automated systems for 3X output without adding headcount.';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = 'https://cc3po.com/wp-content/uploads/2025/04/Color-logo-with-background-scaled.png';
---

<Layout title={SITE_TITLE}>
	<Header />
	
	<style is:global>
		/* Additional styles for SEO badges */
		.hero-badge {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			padding: 8px 16px;
			background: rgba(107,53,255,.1);
			border: 1px solid rgba(107,53,255,.2);
			border-radius: 24px;
			font-size: 13px;
			color: #a78bfa;
			margin-bottom: 20px;
			font-weight: 500;
		}
	</style>
	
	<style>
		/* Page-specific overrides */
		.hero-content {
			text-align: center;
			max-width: 800px;
			margin: 0 auto;
		}
		.hero-content h1 {
			font-size: clamp(36px, 6vw, 64px);
			font-weight: 800;
			line-height: 1.1;
			margin-bottom: 20px;
			background: linear-gradient(135deg, #fff, #a78bfa, #00d2ff);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}
		.hero-content p {
			font-size: clamp(16px, 2vw, 20px);
			color: #a1a1aa;
			margin-bottom: 32px;
		}
		.hero-buttons {
			display: flex;
			gap: 16px;
			justify-content: center;
			flex-wrap: wrap;
		}
		.btn {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			padding: 14px 28px;
			border-radius: 28px;
			text-decoration: none;
			font-weight: 600;
			transition: all 0.2s ease;
		}
		.btn-primary {
			background: linear-gradient(135deg, #6b35ff, #00d2ff);
			color: #fff;
		}
		.btn-primary:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 25px rgba(107,53,255,.4);
		}
		.btn-secondary {
			background: rgba(255,255,255,.05);
			border: 1px solid rgba(255,255,255,.1);
			color: #fff;
		}
		.btn-secondary:hover {
			background: rgba(255,255,255,.1);
			border-color: rgba(107,53,255,.3);
		}
		.stats-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
			gap: 24px;
			text-align: center;
		}
		.stat-item {
			padding: 24px;
		}
		.stat-number {
			font-size: 48px;
			font-weight: 800;
			background: linear-gradient(135deg, #6b35ff, #00d2ff);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
			margin-bottom: 8px;
		}
		.stat-label {
			font-size: 14px;
			color: #a1a1aa;
		}
		.section {
			padding: 80px 24px;
			max-width: 1200px;
			margin: 0 auto;
		}
		.container {
			max-width: 1200px;
			margin: 0 auto;
		}
		.section-header {
			text-align: center;
			margin-bottom: 48px;
		}
		.section-header h2 {
			font-size: clamp(28px, 4vw, 40px);
			font-weight: 700;
			margin-bottom: 12px;
		}
		.section-header p {
			color: #a1a1aa;
			font-size: 16px;
			max-width: 600px;
			margin: 0 auto;
		}
		.cards-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			gap: 20px;
		}
		.card {
			background: linear-gradient(145deg, #141418, #0f0f11);
			border: 1px solid rgba(255,255,255,.06);
			border-radius: 16px;
			padding: 28px;
			transition: all 0.3s ease;
		}
		.card:hover {
			border-color: rgba(107,53,255,.2);
			transform: translateY(-4px);
		}
		.card-icon {
			font-size: 40px;
			margin-bottom: 16px;
		}
		.card h3 {
			font-size: 20px;
			margin-bottom: 12px;
		}
		.card p {
			color: #a1a1aa;
			font-size: 14px;
		}
		.comparison-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
			gap: 24px;
		}
		.comparison-card {
			background: linear-gradient(145deg, #141418, #0f0f11);
			border: 1px solid rgba(255,255,255,.06);
			border-radius: 16px;
			padding: 28px;
		}
		.comparison-card.before {
			border-left: 4px solid #ef4444;
		}
		.comparison-card.after {
			border-left: 4px solid #22c55e;
		}
		.comparison-card h3 {
			font-size: 18px;
			margin-bottom: 20px;
		}
		.comparison-card ul {
			list-style: none;
		}
		.comparison-card li {
			padding: 10px 0;
			border-bottom: 1px solid rgba(255,255,255,.05);
			font-size: 14px;
			color: #a1a1aa;
		}
		.comparison-card li:last-child {
			border-bottom: none;
		}
		.phase-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
			gap: 24px;
		}
		.phase-card {
			background: linear-gradient(145deg, #141418, #0f0f11);
			border: 1px solid rgba(255,255,255,.06);
			border-radius: 16px;
			padding: 32px;
			position: relative;
		}
		.phase-number {
			position: absolute;
			top: 20px;
			right: 20px;
			font-size: 48px;
			font-weight: 800;
			color: rgba(107,53,255,.1);
		}
		.phase-card h3 {
			font-size: 24px;
			margin-bottom: 8px;
		}
		.phase-card ul {
			list-style: none;
			margin-top: 16px;
		}
		.phase-card li {
			padding: 8px 0;
			font-size: 14px;
			color: #a1a1aa;
		}
		.phase-card li::before {
			content: '→';
			color: #6b35ff;
			margin-right: 8px;
		}
		.testimonial-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
			gap: 20px;
		}
		.testimonial-card {
			background: linear-gradient(145deg, #141418, #0f0f11);
			border: 1px solid rgba(255,255,255,.06);
			border-radius: 16px;
			padding: 28px;
		}
		.testimonial-quote {
			font-size: 15px;
			color: #a1a1aa;
			line-height: 1.7;
			font-style: italic;
			margin-bottom: 20px;
		}
		.testimonial-author {
			display: flex;
			align-items: center;
			gap: 12px;
		}
		.testimonial-avatar {
			width: 44px;
			height: 44px;
			background: linear-gradient(135deg, #6b35ff, #00d2ff);
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 700;
			font-size: 16px;
		}
		.testimonial-info h4 {
			font-size: 15px;
			font-weight: 600;
		}
		.testimonial-info p {
			font-size: 13px;
			color: #71717a;
		}
		.cta-section {
			background: linear-gradient(135deg, rgba(107,53,255,.1), rgba(0,210,255,.08));
			border: 1px solid rgba(107,53,255,.15);
			border-radius: 24px;
			padding: 60px;
			text-align: center;
		}
		.cta-section h2 {
			font-size: clamp(24px, 4vw, 36px);
			margin-bottom: 16px;
		}
		.cta-section p {
			color: #a1a1aa;
			margin-bottom: 32px;
			max-width: 600px;
			margin-left: auto;
			margin-right: auto;
		}
		.cta-buttons {
			display: flex;
			gap: 16px;
			justify-content: center;
			flex-wrap: wrap;
		}
		@media (max-width: 768px) {
			.hero-content h1 {
				font-size: 32px;
			}
			.section {
				padding: 60px 16px;
			}
			.cta-section {
				padding: 40px 24px;
			}
			.hero-buttons {
				flex-direction: column;
			}
			.btn {
				width: 100%;
				justify-content: center;
			}
		}
	</style>
	
	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="container">
				<div class="hero-content">
					<span class="hero-badge">Operational Systems Consulting</span>
					<h1>Triple Your Team's Output in 90 Days</h1>
					<p>We eliminate the inefficiencies slowing your team down — and build the systems that let them produce 3X more without burning out or adding headcount.</p>
					<div class="hero-buttons">
						<a href="/audit" class="btn btn-primary">Start Your 3X Productivity Audit →</a>
						<a href="/framework" class="btn btn-secondary">Learn the Framework</a>
					</div>
				</div>
			</div>
		</section>
		
		<!-- Stats Section -->
		<section class="section">
			<div class="container">
				<div class="stats-grid">
					<div class="stat-item">
						<div class="stat-number">3X</div>
						<div class="stat-label">Average productivity gain</div>
					</div>
					<div class="stat-item">
						<div class="stat-number">50+</div>
						<div class="stat-label">Organizations optimized</div>
					</div>
					<div class="stat-item">
						<div class="stat-number">90</div>
						<div class="stat-label">Days to full impact</div>
					</div>
					<div class="stat-item">
						<div class="stat-number">98%</div>
						<div class="stat-label">Client satisfaction</div>
					</div>
				</div>
			</div>
		</section>
		
		<!-- Problem Section -->
		<section class="section" style="background: var(--card);">
			<div class="container">
				<div class="section-header">
					<h2>Why Most Organizations Struggle to Scale</h2>
					<p>It's rarely about effort. Most teams are working hard — just on the wrong things, inside broken systems.</p>
				</div>
				
				<div class="cards-grid">
					<div class="card">
						<div class="card-icon">⚙️</div>
						<h3>Endless Manual Work</h3>
						<p>Teams spend hours copying data, sending the same emails, and updating systems by hand — work that should be automated.</p>
					</div>
					<div class="card">
						<div class="card-icon">📋</div>
						<h3>No Structure or Clarity</h3>
						<p>Responsibilities are unclear, processes are undocumented, and everyone operates on different assumptions.</p>
					</div>
					<div class="card">
						<div class="card-icon">👁️</div>
						<h3>Hidden Inefficiency</h3>
						<p>Bottlenecks are invisible until things break. By then, the cost in time and morale is already compounding.</p>
					</div>
					<div class="card">
						<div class="card-icon">🔴</div>
						<h3>Inconsistent Execution</h3>
						<p>Results depend on who is in the office. When key people are out, work stalls. There's no system — just people.</p>
					</div>
				</div>
				
				<p style="text-align: center; margin-top: 48px; color: var(--accent); font-weight: 600;">
					These four patterns account for the majority of lost productivity. The good news: every one of them is fixable.
				</p>
			</div>
		</section>
		
		<!-- Transformation Section -->
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2>What Changes After Working With Us</h2>
				</div>
				
				<div class="comparison-grid">
					<div class="comparison-card before">
						<h3><span style="color: #ef4444;">✗</span> Before</h3>
						<ul>
							<li>Manual, repetitive tasks eat hours every week</li>
							<li>Responsibilities unclear — things fall through cracks</li>
							<li>No visibility into what the team is delivering</li>
							<li>Results depend entirely on one or two key people</li>
							<li>Slow responses frustrate customers and lose deals</li>
							<li>Growth hits a ceiling — you can't scale what's broken</li>
						</ul>
					</div>
					<div class="comparison-card after">
						<h3><span style="color: #22c55e;">✓</span> After</h3>
						<ul>
							<li>Routine work runs automatically in the background</li>
							<li>Every task has an owner and a clear process</li>
							<li>Real-time dashboards show what matters, instantly</li>
							<li>Systems work consistently, regardless of who's in</li>
							<li>Leads and requests are handled in minutes, not days</li>
							<li>Operations scale with the business, not against it</li>
						</ul>
					</div>
				</div>
				
				<div style="text-align: center; margin-top: 48px;">
					<a href="/audit" class="btn btn-primary">Start Your 3X Productivity Audit →</a>
				</div>
			</div>
		</section>
		
		<!-- How It Works Section -->
		<section class="section" style="background: var(--card);">
			<div class="container">
				<div class="section-header">
					<h2>Three Steps to 3X</h2>
				</div>
				
				<div class="phase-grid">
					<div class="phase-card">
						<span class="phase-number">01</span>
						<h3>Audit</h3>
						<p style="color: var(--muted); margin-bottom: 16px;">You know exactly what's broken.</p>
						<ul>
							<li>Map your workflows</li>
							<li>Identify bottlenecks</li>
							<li>Quantify inefficiency costs</li>
						</ul>
					</div>
					<div class="phase-card">
						<span class="phase-number">02</span>
						<h3>Build</h3>
						<p style="color: var(--muted); margin-bottom: 16px;">Systems replace guesswork.</p>
						<ul>
							<li>Design automations</li>
							<li>Implement processes</li>
							<li>Build scalable structures</li>
						</ul>
					</div>
					<div class="phase-card">
						<span class="phase-number">03</span>
						<h3>Scale</h3>
						<p style="color: var(--muted); margin-bottom: 16px;">3X output. Same team.</p>
						<ul>
							<li>Track results</li>
							<li>Remove remaining friction</li>
							<li>Ensure gains compound</li>
						</ul>
					</div>
				</div>
			</div>
		</section>
		
		<!-- Testimonial Section -->
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2>Proof of 3X</h2>
					<p>Real results from real organizations</p>
				</div>
				
				<div class="testimonial-grid">
					<div class="testimonial-card">
						<p class="testimonial-quote">"CC3PO helped us streamline operations and significantly increase output without adding headcount. Their structured approach made measurable improvements fast."</p>
						<div class="testimonial-author">
							<div class="testimonial-avatar">TN</div>
							<div class="testimonial-info">
								<h4>Theresa Nunnally</h4>
								<p>Leadership Development Strategist</p>
							</div>
						</div>
					</div>
					<div class="testimonial-card">
						<p class="testimonial-quote">"The 3X Framework transformed how we operate. We eliminated 40% of manual processes and redirected that capacity to direct service delivery."</p>
						<div class="testimonial-author">
							<div class="testimonial-avatar">SC</div>
							<div class="testimonial-info">
								<h4>Sarah Chen</h4>
								<p>Executive Director, Healthcare Nonprofit</p>
							</div>
						</div>
					</div>
					<div class="testimonial-card">
						<p class="testimonial-quote">"CC3PO didn't just automate tasks — they redesigned our operational architecture. We're now processing 3X the volume with the same team size."</p>
						<div class="testimonial-author">
							<div class="testimonial-avatar">MR</div>
							<div class="testimonial-info">
								<h4>Michael Rodriguez</h4>
								<p>Operations Manager, Social Services Agency</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
		
		<!-- CTA Section -->
		<section class="section">
			<div class="container">
				<div class="cta-section">
					<h2>Ready to Achieve 3X Productivity?</h2>
					<p>We'll audit your operations, identify what's holding your team back, and deliver a clear roadmap to triple your output in 90 days.</p>
					<div class="cta-buttons">
						<a href="/audit" class="btn btn-primary">Start Your 3X Productivity Audit →</a>
						<a href="/case-studies" class="btn btn-secondary">See Case Studies</a>
					</div>
				</div>
			</div>
		</section>
		
		<!-- Trusted By Section -->
		<section class="section" style="padding-top: 0;">
			<div class="container">
				<div class="section-header">
					<h2>Trusted by Growing Organizations</h2>
					<p>Measurable outcomes from organizations that invested in strategic operational transformation</p>
				</div>
				
				<div class="stats-grid">
					<div class="stat-item">
						<div class="stat-number">3X</div>
						<div class="stat-label">Average Productivity Gain<br><span style="font-size: 11px; color: #666;">Within 12 months</span></div>
					</div>
					<div class="stat-item">
						<div class="stat-number">60%</div>
						<div class="stat-label">Reduction in Manual Workflows<br><span style="font-size: 11px; color: #666;">Through automation</span></div>
					</div>
					<div class="stat-item">
						<div class="stat-number">500+</div>
						<div class="stat-label">Staff Hours Reclaimed<br><span style="font-size: 11px; color: #666;">Per organization annually</span></div>
					</div>
					<div class="stat-item">
						<div class="stat-number">98%</div>
						<div class="stat-label">Client Satisfaction<br><span style="font-size: 11px; color: #666;">Would recommend</span></div>
					</div>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>