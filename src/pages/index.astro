---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import TrustBar from '../components/TrustBar.astro';
import ProblemSection from '../components/ProblemSection.astro';
import MarketOpportunity from '../components/MarketOpportunity.astro';
import SolutionSection from '../components/SolutionSection.astro';
import ProductChain from '../components/ProductChain.astro';
import TechnologyEdge from '../components/TechnologyEdge.astro';
import CompetitiveLandscape from '../components/CompetitiveLandscape.astro';
import DentalFirstSection from '../components/DentalFirstSection.astro';
import RevenueSection from '../components/RevenueSection.astro';
import SetupFlow from '../components/SetupFlow.astro';
import InvestSection from '../components/InvestSection.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import FloatingCTA from '../components/FloatingCTA.astro';

const title = 'Invest in CC3PO | AI-Powered Business Automation Seed Round';
const description = 'Invest in CC3PO — the AI Village of integrated SaaS products eliminating manual work across healthcare, dental, and service-based businesses. Seed round opportunity with verified market data: $5.1T IT spend, $69.4B combined practice management TAM, 92% client retention.';
---

<Layout title={title} description={description}>
  <Header />
  
  <main>
    <HeroSection />
    <TrustBar />
    <ProblemSection />
    <MarketOpportunity />
    <SolutionSection />
    <ProductChain />
    <TechnologyEdge />
    <CompetitiveLandscape />
    <DentalFirstSection />
    <RevenueSection />
    <SetupFlow />
    <InvestSection />
  </main>
  
  <Footer />
  <CookieConsent />
  <FloatingCTA />
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  section {
    opacity: 0.97;
    transition: opacity 0.3s;
  }
  :focus-visible {
    outline: 2px solid var(--accent-cyan);
    outline-offset: 2px;
  }
</style>
