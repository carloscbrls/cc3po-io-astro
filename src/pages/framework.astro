---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="3X Framework - CC3PO">
	<Header />
	
	<main>
		<section class="hero" style="min-height: 50vh;">
			<div class="container">
				<div class="hero-content">
					<span class="hero-badge">The System Behind 3X</span>
					<h1>Most Teams Don't Have a Productivity Problem</h1>
					<p style="font-size: 1.5rem;">They have a <strong style="color: var(--accent);">systems problem</strong> — and it's costing them time, money, and growth.</p>
					<div class="hero-buttons" style="margin-top: 32px;">
						<a href="/audit" class="btn btn-primary">Find What's Slowing You Down →</a>
					</div>
				</div>
			</div>
		</section>
		
		<!-- Problem Section -->
		<section class="section" style="background: var(--card);">
			<div class="container">
				<div class="section-header">
					<h2>Why Productivity Breaks Down</h2>
				</div>
				
				<div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));">
					<div class="stat-item" style="padding: 24px;">
						<div style="font-size: 2rem; margin-bottom: 8px;">⚙️</div>
						<div class="stat-label" style="font-weight: 600; color: var(--text);">Too much manual work</div>
					</div>
					<div class="stat-item" style="padding: 24px;">
						<div style="font-size: 2rem; margin-bottom: 8px;">📋</div>
						<div class="stat-label" style="font-weight: 600; color: var(--text);">No consistent processes</div>
					</div>
					<div class="stat-item" style="padding: 24px;">
						<div style="font-size: 2rem; margin-bottom: 8px;">👁️</div>
						<div class="stat-label" style="font-weight: 600; color: var(--text);">Lack of visibility</div>
					</div>
					<div class="stat-item" style="padding: 24px;">
						<div style="font-size: 2rem; margin-bottom: 8px;">🔴</div>
						<div class="stat-label" style="font-weight: 600; color: var(--text);">Constant bottlenecks</div>
					</div>
				</div>
				
				<div style="background: rgba(107, 53, 255, 0.1); border-radius: 16px; padding: 32px; margin-top: 48px;">
					<h3 style="margin-bottom: 16px;">If This Feels Familiar…</h3>
					<ul style="list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
						<li style="display: flex; align-items: center; gap: 12px; color: var(--muted);">
							<span style="color: var(--accent);">→</span> Your team is busy, but output isn't improving
						</li>
						<li style="display: flex; align-items: center; gap: 12px; color: var(--muted);">
							<span style="color: var(--accent);">→</span> Work keeps getting repeated or delayed
						</li>
						<li style="display: flex; align-items: center; gap: 12px; color: var(--muted);">
							<span style="color: var(--accent);">→</span> No clear visibility into performance
						</li>
						<li style="display: flex; align-items: center; gap: 12px; color: var(--muted);">
							<span style="color: var(--accent);">→</span> Everything depends on a few key people
						</li>
					</ul>
				</div>
			</div>
		</section>
		
		<!-- Traditional vs 3X Section -->
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2>Most Organizations Try to Fix This the Wrong Way</h2>
				</div>
				
				<div class="comparison-grid">
					<div class="comparison-card before">
						<h3><span style="color: #ef4444;">✗</span> Traditional Approach</h3>
						<ul>
							<li>Hire more people</li>
							<li>Adopt random tools</li>
							<li>React to every problem</li>
							<li>Run fragmented initiatives</li>
							<li>No measurement, no feedback</li>
						</ul>
					</div>
					<div class="comparison-card after">
						<h3><span style="color: #22c55e;">✓</span> 3X Framework</h3>
						<ul>
							<li>Build systematic foundations</li>
							<li>Measure what matters</li>
							<li>Eliminate root causes</li>
							<li>Integrate improvements</li>
							<li>Compound gains over time</li>
						</ul>
					</div>
				</div>
			</div>
		</section>
		
		<!-- The 3 Phases -->
		<section class="section" style="background: var(--card);">
			<div class="container">
				<div class="section-header">
					<h2>There's a Better Way to Scale Output</h2>
					<p>A structured system designed to remove friction and multiply results — one phase at a time.</p>
				</div>
				
				<div class="phase-grid">
					<div class="phase-card">
						<span class="phase-number">01</span>
						<h3>Construct</h3>
						<p style="color: var(--muted); margin-bottom: 16px;">Build the foundation for scalable operations. Most teams skip this — which is exactly why improvements don't stick.</p>
						<ul>
							<li>Define and document processes</li>
							<li>Align responsibilities across teams</li>
							<li>Establish the operational structure</li>
						</ul>
						<div class="phase-highlight">Free up 40–60% of your team's time</div>
					</div>
					<div class="phase-card">
						<span class="phase-number">02</span>
						<h3>Calibrate</h3>
						<p style="color: var(--muted); margin-bottom: 16px;">Optimize performance through data and refinement. With a foundation in place, you can measure what matters.</p>
						<ul>
							<li>Identify and remove bottlenecks</li>
							<li>Improve workflow efficiency</li>
							<li>Introduce feedback loops</li>
						</ul>
						<div class="phase-highlight">Get 25–35% more output without hiring</div>
					</div>
					<div class="phase-card">
						<span class="phase-number">03</span>
						<h3>Compound</h3>
						<p style="color: var(--muted); margin-bottom: 16px;">Create systems that improve over time. Each cycle builds on the last — generating results that scale with the business.</p>
						<ul>
							<li>Run continuous improvement cycles</li>
							<li>Deploy scalable systems</li>
							<li>Build long-term growth architecture</li>
						</ul>
						<div class="phase-highlight">Scale your output without scaling your team</div>
					</div>
				</div>
				
				<div style="text-align: center; margin-top: 48px;">
					<a href="/audit" class="btn btn-primary">Start My 3X Productivity Audit →</a>
				</div>
			</div>
		</section>
		
		<!-- The System -->
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2>The System Behind 3X</h2>
				</div>
				
				<div class="cards-grid">
					<div class="card">
						<div class="card-icon" style="font-size: 18px; font-weight: 800;">X1</div>
						<h3>Clarity</h3>
						<p>Strategic alignment and operational visibility — so every team member knows what to optimize.</p>
					</div>
					<div class="card">
						<div class="card-icon" style="font-size: 18px; font-weight: 800;">X2</div>
						<h3>Coordination</h3>
						<p>Connected workflows and integrated systems that eliminate friction across the organization.</p>
					</div>
					<div class="card">
						<div class="card-icon" style="font-size: 18px; font-weight: 800;">X3</div>
						<h3>Compounding Efficiency</h3>
						<p>Automation and continuous improvement that generates exponential productivity gains over time.</p>
					</div>
				</div>
				
				<p style="text-align: center; margin-top: 32px; color: var(--accent); font-weight: 600;">
					Each pillar reinforces the others — the system improves itself.
				</p>
			</div>
		</section>
		
		<!-- Results -->
		<section class="section" style="background: var(--card);">
			<div class="container">
				<div class="section-header">
					<h2>What This Actually Looks Like</h2>
				</div>
				
				<div class="stats-grid">
					<div class="stat-item">
						<div class="stat-number">3X</div>
						<div class="stat-label">Output Capacity</div>
					</div>
					<div class="stat-item">
						<div class="stat-number">60%</div>
						<div class="stat-label">Less Manual Work</div>
					</div>
					<div class="stat-item">
						<div class="stat-number">500+</div>
						<div class="stat-label">Hours Reclaimed</div>
					</div>
					<div class="stat-item">
						<div class="stat-number">98%</div>
						<div class="stat-label">Client Satisfaction</div>
					</div>
				</div>
			</div>
		</section>
		
		<!-- CTA -->
		<section class="section">
			<div class="container">
				<div class="cta-section">
					<h2>Ready to Fix What's Slowing You Down?</h2>
					<p>Start with a simple audit. No pressure. Just clarity.</p>
					<p style="color: var(--accent); margin-bottom: 24px;">Every month without structure compounds inefficiency.</p>
					<a href="/audit" class="btn btn-primary">Start My 3X Productivity Audit →</a>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>