---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Case Studies - CC3PO">
	<Header />
	
	<main>
		<section class="hero" style="min-height: 40vh;">
			<div class="container">
				<div class="hero-content">
					<span class="hero-badge">Proven Results</span>
					<h1>Case Studies</h1>
					<p style="font-size: 1.25rem;">Real organizations achieving measurable, sustainable productivity improvements through systematic optimization.</p>
				</div>
			</div>
		</section>
		
		<!-- Featured Case Study -->
		<section class="section">
			<div class="container">
				<div class="case-study-card" style="margin-bottom: 32px;">
					<div class="case-study-header">
						<span class="case-study-tag">Featured</span>
						<h3>From Bottlenecks to 3X Productivity</h3>
						<p>Leadership Development Organization • How CC3PO helped streamline operations, eliminate inefficiencies, and unlock scalable output.</p>
					</div>
					<div class="case-study-stats">
						<div class="case-study-stat">
							<div class="case-study-stat-value">3X</div>
							<div class="case-study-stat-label">Output increase</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">60%</div>
							<div class="case-study-stat-label">Faster execution</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">100%</div>
							<div class="case-study-stat-label">Team alignment</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">Zero</div>
							<div class="case-study-stat-label">New hires needed</div>
						</div>
					</div>
					<div class="case-study-body">
						<a href="/case-studies/3x-productivity-audit" class="btn btn-primary" style="display: inline-flex;">Read Full Case Study →</a>
					</div>
				</div>
			</div>
		</section>
		
		<!-- GlobalHealth Initiative Case Study -->
		<section class="section" style="background: var(--card);">
			<div class="container">
				<div class="case-study-card">
					<div class="case-study-header">
						<span class="case-study-tag">Healthcare Nonprofit • 85 employees</span>
						<h3>GlobalHealth Initiative: 3.2X Delivery Capacity Without Additional Headcount</h3>
					</div>
					<div class="case-study-stats">
						<div class="case-study-stat">
							<div class="case-study-stat-value">3.2X</div>
							<div class="case-study-stat-label">Delivery capacity</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">$890K</div>
							<div class="case-study-stat-label">Annual savings</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">62%</div>
							<div class="case-study-stat-label">Less admin time</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">95%</div>
							<div class="case-study-stat-label">Employee satisfaction</div>
						</div>
					</div>
					<div class="case-study-body">
						<div class="case-study-section">
							<h4>The Challenge</h4>
							<p>Rapidly growing mission-critical programs were constrained by operational bottlenecks. The team struggled to scale delivery without proportional headcount increases, leading to missed deadlines and burnout.</p>
						</div>
						<div class="case-study-section">
							<h4>The Solution</h4>
							<p>Implemented the complete 3X Framework over 16 weeks, starting with process documentation (Construct), followed by workflow automation and resource optimization (Calibrate), and establishing continuous improvement cycles (Compound).</p>
						</div>
						<div class="case-study-section">
							<h4>Key Outcomes</h4>
							<ul>
								<li>Automated grant reporting process, reducing preparation time from 40 hours to 8 hours per report</li>
								<li>Implemented knowledge management system that cut new employee onboarding from 6 weeks to 10 days</li>
								<li>Established real-time performance dashboard providing leadership with instant operational visibility</li>
								<li>Created feedback loops that identified and resolved bottlenecks within 48 hours of emergence</li>
							</ul>
						</div>
						<div class="testimonial-card" style="margin-top: 24px;">
							<p class="testimonial-quote">"CC3PO transformed our operations completely. Within 90 days, we achieved a 3.2X increase in project delivery capacity without adding headcount. The systematic approach eliminated guesswork and gave us confidence in every optimization decision."</p>
							<div class="testimonial-author">
								<div class="testimonial-avatar">SM</div>
								<div class="testimonial-info">
									<h4>Sarah Mitchell</h4>
									<p>Chief Operating Officer, GlobalHealth Initiative</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
		
		<!-- Education Forward Case Study -->
		<section class="section">
			<div class="container">
				<div class="case-study-card">
					<div class="case-study-header">
						<span class="case-study-tag">Education Nonprofit • 120 employees</span>
						<h3>Education Forward: $2.4M Annual Savings Through Resource Optimization</h3>
					</div>
					<div class="case-study-stats">
						<div class="case-study-stat">
							<div class="case-study-stat-value">$2.4M</div>
							<div class="case-study-stat-label">Annual savings</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">2.8X</div>
							<div class="case-study-stat-label">Efficiency improvement</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">47%</div>
							<div class="case-study-stat-label">Less overhead</div>
						</div>
						<div class="case-study-stat">
							<div class="case-study-stat-value">100%</div>
							<div class="case-study-stat-label">Process standardization</div>
						</div>
					</div>
					<div class="case-study-body">
						<div class="case-study-section">
							<h4>The Challenge</h4>
							<p>Fragmented processes across 15 regional offices created duplication, inconsistency, and massive inefficiency. Leadership lacked visibility into resource allocation and couldn't identify improvement opportunities.</p>
						</div>
						<div class="case-study-section">
							<h4>The Solution</h4>
							<p>Conducted comprehensive 3X Productivity Audit followed by 12-week Calibrate engagement focused on standardization, resource optimization, and performance monitoring across all locations.</p>
						</div>
						<div class="case-study-section">
							<h4>Key Outcomes</h4>
							<ul>
								<li>Consolidated 23 separate workflows into 8 standardized, optimized processes</li>
								<li>Implemented centralized resource allocation system that eliminated redundant efforts</li>
								<li>Established performance metrics dashboard providing real-time visibility across all offices</li>
								<li>Created training materials that reduced new regional office setup time from 6 months to 4 weeks</li>
							</ul>
						</div>
						<div class="testimonial-card" style="margin-top: 24px;">
							<p class="testimonial-quote">"The 3X Productivity Audit revealed inefficiencies we didn't know existed. The roadmap was clear, actionable, and resulted in $2.4M in cost savings through optimized resource allocation."</p>
							<div class="testimonial-author">
								<div class="testimonial-avatar">JC</div>
								<div class="testimonial-info">
									<h4>James Chen</h4>
									<p>Executive Director, Education Forward</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
		
		<!-- CTA -->
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2>Ready for Similar Results?</h2>
					<p>Every organization has unique challenges, but the 3X Framework delivers consistent, measurable improvements.</p>
				</div>
				<div class="cta-section">
					<div class="cta-buttons">
						<a href="https://scheduler.zoom.us/carlos-cabrales-iii/3x-strategy-consultation" class="btn btn-primary">Schedule a 3X Strategy Consultation →</a>
						<a href="/audit" class="btn btn-secondary">Explore 3X Audit</a>
					</div>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>