<style>
  .legal-page { padding: 120px 24px 60px; min-height: 60vh; }
  .container { max-width: 800px; margin: 0 auto; }
  h1 { font-family: 'Space Grotesk', system-ui, sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; margin-bottom: 8px; background: linear-gradient(135deg, #fff, #4cc9f0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .last-updated { color: var(--text-muted); font-size: 14px; margin-bottom: 40px; }
  .content { color: var(--text-muted); font-size: 15px; line-height: 1.7; }
  .content h2 { font-family: 'Space Grotesk', system-ui, sans-serif; font-size: 20px; font-weight: 600; color: #fff; margin: 32px 0 12px; }
  .content p { margin-bottom: 16px; }
  .content ul { margin-left: 24px; margin-bottom: 16px; }
  .content li { margin-bottom: 8px; }
  .content a { color: var(--accent-cyan); text-decoration: none; }
  .content a:hover { text-decoration: underline; }
  @media (max-width: 768px) { .legal-page { padding: 100px 16px 40px; } }
</style>
