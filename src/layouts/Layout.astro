---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Invest in the Future of AI-Powered Business Automation. CC3PO is building an AI Village of integrated SaaS products that eliminate manual work across healthcare, dental, and service-based businesses.' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://cc3po.io');
const ogImage = 'https://cc3po.io/og-investor.png';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#050508" />

		<link rel="canonical" href="https://cc3po.io" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/favicon.png" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:site_name" content="CC3PO" />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "CC3PO",
			"url": "https://cc3po.io",
			"logo": "https://cc3po.io/images/cc3po-logo.png",
			"description": "AI-Powered Business Automation. An AI Village of integrated SaaS products eliminating manual work.",
			"founder": {
				"@type": "Person",
				"name": "Carlos Cabrales",
				"jobTitle": "Founder & CEO"
			},
			"sameAs": [
				"https://linkedin.com/company/cc3potechnology",
				"https://x.com/IiiCabrales",
				"https://instagram.com/carloscbrls",
				"https://facebook.com/CC3PO",
				"https://www.tiktok.com/@carlos.a.k.ac3",
				"https://www.youtube.com/@carloscbrls"
			],
			"contactPoint": {
				"@type": "ContactPoint",
				"email": "invest@cc3po.com",
				"contactType": "Investor Relations"
			}
		}
		</script>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "InvestmentFund",
			"name": "CC3PO Seed Round",
			"description": "Pre-seed investment in CC3PO LLC, autonomous AI workforce infrastructure",
			"offers": {
				"@type": "Offer",
				"price": "500000",
				"priceCurrency": "USD",
				"description": "Pre-seed round"
			},
			"minimumInvestment": {
				"@type": "MonetaryAmount",
				"currency": "USD",
				"value": "10000"
			}
		}
		</script>

		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
