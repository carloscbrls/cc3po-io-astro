---
const stats = [
	{ num: '2.5 hrs/day', label: 'lost to repetitive tasks', source: 'McKinsey' },
	{ num: '254', label: 'SaaS tools average enterprise uses', source: 'BetterCloud' },
	{ num: '40–45%', label: 'of work is automatable', source: 'Harvard Business Review' },
];
---

<section class="section" id="problem">
	<div class="container">
		<div class="problem-grid">
			{stats.map(s => (
				<div class="stat-card">
					<div class="stat-num">{s.num}</div>
					<div class="stat-label">{s.label}</div>
					<div class="stat-source">Source: {s.source}</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.problem-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
	}
	.stat-card {
		padding: 40px 24px;
		border-radius: 16px;
		border: 1px solid var(--border);
		background: var(--surface);
		text-align: center;
		transition: border-color 0.3s;
	}
	.stat-card:hover {
		border-color: var(--border-hover);
	}
	.stat-num {
		font-size: clamp(2rem, 3vw, 3rem);
		font-weight: 800;
		letter-spacing: -1px;
		color: var(--text-primary);
		margin-bottom: 8px;
	}
	.stat-label {
		font-size: 14px;
		color: var(--text-secondary);
		margin-bottom: 12px;
		line-height: 1.5;
	}
	.stat-source {
		font-size: 11px;
		color: var(--text-muted);
	}
	@media (max-width: 768px) {
		.problem-grid { grid-template-columns: 1fr; }
	}
</style>
