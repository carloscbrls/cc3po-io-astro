<section class="trust-bar" id="trust-bar">
	<div class="container">
		<p>
			<span class="trust-item">450M+ workflows/month</span>
			<span class="trust-sep">·</span>
			<span class="trust-item">91.2% accuracy</span>
			<span class="trust-sep">·</span>
			<span class="trust-item">200–400% ROI</span>
			<span class="trust-sep">·</span>
			<span class="trust-item">60% of Fortune 500 running agentic AI</span>
		</p>
	</div>
</section>

<style>
	.trust-bar {
		padding: 24px 0;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		text-align: center;
	}
	.trust-bar p {
		font-size: 13px;
		color: var(--text-secondary);
		margin: 0;
		letter-spacing: 0.02em;
	}
	.trust-sep {
		color: var(--text-muted);
		margin: 0 12px;
	}
	@media (max-width: 768px) {
		.trust-bar p { font-size: 12px; line-height: 2; }
		.trust-sep { margin: 0 6px; }
	}
</style>
