---
const stats = [
	{ num: '3–5x', label: 'faster', source: 'Microsoft Research' },
	{ num: '91.2%', label: 'accuracy vs 78.3% single agent (SWE-bench)', source: 'SWE-bench' },
	{ num: '100–500x', label: 'cheaper than human labor', source: 'Anthropic + BLS' },
	{ num: '200–400%', label: 'ROI within 18 months', source: 'Deloitte' },
];
---

<section class="section" id="research">
	<div class="container">
		<div class="tech-header">
			<h2>Why Multi-Agent Wins</h2>
		</div>
		<div class="tech-grid">
			{stats.map(s => (
				<div class="tech-card">
					<div class="tech-num">{s.num}</div>
					<div class="tech-label">{s.label}</div>
					<div class="tech-source">Source: {s.source}</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.tech-header {
		text-align: center;
		margin-bottom: 64px;
	}
	.tech-header h2 { letter-spacing: -1.5px; }
	.tech-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 24px;
	}
	.tech-card {
		padding: 40px 32px;
		border-radius: 16px;
		border: 1px solid var(--border);
		background: var(--surface);
		transition: border-color 0.3s;
	}
	.tech-card:hover { border-color: var(--border-hover); }
	.tech-num {
		font-size: clamp(2rem, 3vw, 2.75rem);
		font-weight: 800;
		letter-spacing: -1px;
		color: var(--text-primary);
		margin-bottom: 8px;
	}
	.tech-label {
		font-size: 15px;
		color: var(--text-secondary);
		margin-bottom: 12px;
		line-height: 1.5;
	}
	.tech-source {
		font-size: 12px;
		color: var(--text-muted);
	}
	@media (max-width: 768px) {
		.tech-grid { grid-template-columns: 1fr; }
	}
</style>
