---
const steps = [
	{ num: '1', label: 'Connect', time: '5 min', desc: 'Link your existing systems' },
	{ num: '2', label: 'Train', time: '1 day', desc: 'Teach the agents your rules' },
	{ num: '3', label: 'Automate', time: 'forever', desc: 'Run on autopilot, you approve' },
];
---

<section class="section" id="setup">
	<div class="container">
		<div class="setup-header">
			<h2>Get Started in 3 Steps</h2>
		</div>
		<div class="setup-flow">
			{steps.map((s, i) => (
				<div class="setup-step" style={`--delay: ${i * 0.15}s`}>
					<div class="setup-num">{s.num}</div>
					<div class="setup-label">{s.label}</div>
					<div class="setup-time">{s.time}</div>
					<div class="setup-desc">{s.desc}</div>
					{i < steps.length - 1 && <div class="setup-arrow" aria-hidden="true">→</div>}
				</div>
			))}
		</div>
		<p class="setup-trust">Your systems. Your rules. You approve before anything ships.</p>
	</div>
</section>

<style>
	.setup-header { text-align: center; margin-bottom: 64px; }
	.setup-header h2 { letter-spacing: -1.5px; }
	.setup-flow {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		gap: 48px;
		flex-wrap: wrap;
		max-width: 900px;
		margin: 0 auto;
	}
	.setup-step {
		flex: 1;
		min-width: 200px;
		max-width: 240px;
		text-align: center;
		position: relative;
		animation: fadeUp 0.6s ease forwards;
		animation-delay: var(--delay);
		opacity: 0;
	}
	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(12px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.setup-num {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		border: 1px solid var(--border);
		background: var(--surface);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 18px;
		font-weight: 700;
		color: var(--accent-cyan);
		margin: 0 auto 16px;
	}
	.setup-label {
		font-size: 18px;
		font-weight: 700;
		letter-spacing: -0.3px;
		color: var(--text-primary);
		margin-bottom: 4px;
	}
	.setup-time {
		font-size: 13px;
		font-weight: 600;
		color: var(--accent-cyan);
		margin-bottom: 8px;
	}
	.setup-desc {
		font-size: 14px;
		color: var(--text-secondary);
		line-height: 1.5;
	}
	.setup-arrow {
		position: absolute;
		right: -32px;
		top: 12px;
		font-size: 20px;
		color: var(--text-muted);
	}
	.setup-trust {
		text-align: center;
		margin-top: 48px;
		font-size: 15px;
		color: var(--text-muted);
	}
	@media (max-width: 768px) {
		.setup-flow { flex-direction: column; align-items: center; gap: 32px; }
		.setup-arrow { display: none; }
	}
</style>
